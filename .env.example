# To understand what each env variable does and how it's used, check out the config.go
# of the associated package. E.g. FIREHOSE_KINDS is defined pkg/pipe/firehose/config.go

# System (pkg/config)
REDIS_ADDRESS=localhost:6379
SQLITE_PATH=events.sqlite
INIT_PUBKEYS=3bf0c63fcb93463407af97a5e5ee64fa883d107ef9e558472c4eb9aaaefa459d

# Pool (pkg/pipe/pool)
POOL_AUTH_KEY=
POOL_RELAYS=wss://relay.damus.io,wss://relay.primal.net,wss://purplepag.es,wss://njump.me,wss://relay.snort.social
POOL_RELAY_RETRY=10m
POOL_SUB_RETRY=10s


# Firehose (pkg/pipe/firehose)
FIREHOSE_KINDS=0,1,3,6,7,16,20,21,22,1111,9321,9735,10000,10002,10063,30023
FIREHOSE_OFFSET=1m
FIREHOSE_FILTER_CACHE_SIZE=100000


# Recorder (pkg/pipe/recorder)
RECORDER_QUEUE=10000


# Fetcher (pkg/pipe/fetcher)
FETCHER_KINDS=0,3,10000,10002,10063
FETCHER_QUEUE=10000
FETCHER_BATCH=100
FETCHER_INTERVAL=1m
FETCHER_TIMEOUT=20s


# Arbiter (pkg/pipe/arbiter)
ARBITER_ACTIVATION=0.01
ARBITER_PROMOTION=0.01
ARBITER_DEMOTION=0.0
ARBITER_PROMOTION_WAIT=0s
ARBITER_POLL_INTERVAL=10s
ARBITER_PRINT_STATS=true
ARBITER_SCAN_TIMEOUT=2m


# Engine (pkg/pipe/engine)
ENGINE_QUEUE=10000
ENGINE_CACHE_CAPACITY=100000
ENGINE_PRINT_EVERY=10000
ENGINE_TIMEOUT=10s
